OPENAI_API_KEY=sua_chave_aqui

OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_TEMPERATURE=1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

MAX_RELEVANCE_SCORE=1.2
MAX_DISPLAY_SOURCE_SCORE=1.0
DISPLAY_SOURCE_SCORE_MARGIN=0.15
MAX_UPLOAD_FILE_SIZE_MB=10
MIN_ENRICHED_CHUNK_QUALITY_SCORE=0.5

DATABASE_URL=postgresql://smartdocs:smartdocs@postgres:5432/smartdocs
REDIS_URL=redis://redis:6379/0
CHAT_RATE_LIMIT_PER_IP_DAILY=30
CHAT_RATE_LIMIT_GLOBAL_DAILY=300

JWT_SECRET_KEY=troque_esta_chave_em_producao
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_COOKIE_NAME=smartdocs_admin_access_token
FRONTEND_ORIGINS=http://localhost:2000
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Exemplo de producao:
# FRONTEND_ORIGINS=https://smartdocs.fredtamashiro.com.br
# COOKIE_DOMAIN=.fredtamashiro.com.br
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
